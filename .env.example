# loop-mcp environment variables
# Copy to .env and fill in values (never commit .env to git)

# Phoenixd connection (Railway internal network)
PHOENIXD_URL=http://phoenixd.railway.internal:9740
PHOENIXD_PASSWORD=your-phoenixd-password-here

# Pricing
MCP_PRICE_SATS=10

# Gin mode (release | debug)
GIN_MODE=release

# Port (Railway sets this automatically)
PORT=8080
